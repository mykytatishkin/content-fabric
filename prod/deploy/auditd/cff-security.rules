# CFF security audit rules — feed to /etc/audit/rules.d/cff-security.rules
#
# Designed around the threat model from the May 2026 incident response:
#   1. Public Redis -> cron-based RCE (cryptominer)
#   2. SSH brute-force (286k attempts, 44k bans)
#   3. Suspicious 04:00 root SSH from external VPS
#
# Goal: every privileged action, every credential mutation, every change to
# code/config/firewall is recorded with a tag we can query in Grafana.
#
# Tags (-k) become structured labels in promtail/Loki.
#
# NOTE: comments must be plain ASCII; augenrules silently truncates rule
# loading at the first non-ASCII character.

# Identity & credentials
-w /etc/passwd          -p wa -k cff-identity
-w /etc/shadow          -p wa -k cff-identity
-w /etc/group           -p wa -k cff-identity
-w /etc/gshadow         -p wa -k cff-identity
-w /etc/sudoers         -p wa -k cff-sudoers
-w /etc/sudoers.d/      -p wa -k cff-sudoers
-w /etc/security/       -p wa -k cff-identity
-w /etc/pam.d/          -p wa -k cff-pam

# SSH
-w /etc/ssh/sshd_config            -p wa -k cff-ssh-config
-w /etc/ssh/sshd_config.d/         -p wa -k cff-ssh-config
-w /root/.ssh/                     -p wa -k cff-ssh-keys

# Privilege escalation binaries
-w /usr/bin/sudo        -p x -k cff-priv-exec
-w /usr/bin/su          -p x -k cff-priv-exec
-w /usr/bin/passwd      -p x -k cff-priv-exec
-w /usr/bin/chsh        -p x -k cff-priv-exec
-w /usr/bin/chfn        -p x -k cff-priv-exec
-w /usr/bin/newgrp      -p x -k cff-priv-exec
-w /usr/bin/gpasswd     -p x -k cff-priv-exec

# Cron (primary RCE persistence vector seen in this incident)
-w /etc/crontab         -p wa -k cff-cron
-w /etc/cron.d/         -p wa -k cff-cron
-w /etc/cron.hourly/    -p wa -k cff-cron
-w /etc/cron.daily/     -p wa -k cff-cron
-w /etc/cron.weekly/    -p wa -k cff-cron
-w /etc/cron.monthly/   -p wa -k cff-cron
-w /var/spool/cron/     -p wa -k cff-cron

# systemd units (services + timers, used by malware for persistence)
-w /etc/systemd/system/    -p wa -k cff-systemd
-w /lib/systemd/system/    -p wa -k cff-systemd
-w /etc/init.d/            -p wa -k cff-systemd

# Firewall / network config
-w /etc/iptables/                  -p wa -k cff-firewall
-w /etc/network/                   -p wa -k cff-network
-w /etc/hosts                      -p wa -k cff-network
-w /etc/resolv.conf                -p wa -k cff-network
-w /etc/nsswitch.conf              -p wa -k cff-network

# nginx / web layer config
-w /etc/nginx/                                          -p wa -k cff-nginx

# Application code + secrets
-w /opt/content-fabric/.env                             -p rwa -k cff-secrets
-w /opt/content-fabric/prod/main.py                     -p wa  -k cff-code-critical
-w /opt/content-fabric/prod/app/core/security.py        -p wa  -k cff-code-critical
-w /opt/content-fabric/prod/app/api/deps.py             -p wa  -k cff-code-critical

# Yii archive — ONLY code paths, not data/streams/ (streams ffmpeg
# touches data/ thousands of times per minute, would flood the log).
-w /var/www/fastuser/data/www/aiyoutube.pbnbots.com/yii      -p w -k cff-yii-legacy
-w /var/www/fastuser/data/www/aiyoutube.pbnbots.com/protected -p w -k cff-yii-legacy

# Module load/unload (rootkit indicator)
-a always,exit -F arch=b64 -S init_module,delete_module,finit_module -k cff-module
-a always,exit -F arch=b32 -S init_module,delete_module,finit_module -k cff-module
-w /etc/modprobe.d/      -p wa -k cff-module
-w /etc/modules-load.d/  -p wa -k cff-module

# Time changes (attackers often manipulate to mask activity)
-a always,exit -F arch=b64 -S adjtimex,settimeofday,clock_settime -k cff-time
-a always,exit -F arch=b32 -S adjtimex,settimeofday,clock_settime -k cff-time
-w /etc/localtime        -p wa -k cff-time

# docker daemon config (containers used in observability stack)
-w /etc/docker/             -p wa -k cff-docker

# Mount/umount (filesystem attachment - rootkit, exfil)
-a always,exit -F arch=b64 -S mount -k cff-mount
-a always,exit -F arch=b32 -S mount -k cff-mount

# Outgoing privileged binary executions for non-root -> root
# audit any user transition to UID 0 via execve
-a always,exit -F arch=b64 -F euid=0 -S execve -F auid>=1000 -F auid!=4294967295 -k cff-priv-launch
-a always,exit -F arch=b32 -F euid=0 -S execve -F auid>=1000 -F auid!=4294967295 -k cff-priv-launch
