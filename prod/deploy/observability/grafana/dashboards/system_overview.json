{
  "uid": "cff-system",
  "title": "CFF — System Overview",
  "tags": ["cff", "overview"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {"from": "now-3h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "type": "stat",
      "title": "API up",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"cff-api\"}", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["last"]}},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}, "type": "value"}]}}
    },
    {
      "type": "stat",
      "title": "Workers up",
      "id": 2,
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count(namedprocess_namegroup_num_procs{groupname=~\"cff-.*\"} > 0)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Streams running",
      "id": 3,
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(cff_stream_active)", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 5, "color": "yellow"}, {"value": 9, "color": "green"}]}}}
    },
    {
      "type": "stat",
      "title": "Disk free %",
      "id": 4,
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 * node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 15, "color": "yellow"}, {"value": 30, "color": "green"}]}}}
    },
    {
      "type": "stat",
      "title": "RAM used %",
      "id": 5,
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "type": "stat",
      "title": "DLE sources up",
      "id": 6,
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(cff_dle_source_up)", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 5, "color": "yellow"}, {"value": 7, "color": "green"}]}}}
    },

    {
      "type": "timeseries",
      "title": "Worker memory (RSS)",
      "id": 10,
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "namedprocess_namegroup_memory_bytes{groupname=~\"cff-.*\", memtype=\"resident\"}", "legendFormat": "{{groupname}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "timeseries",
      "title": "Queue depth",
      "id": 11,
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_queue_depth", "legendFormat": "{{queue}}", "refId": "A"}]
    },

    {
      "type": "timeseries",
      "title": "Tasks by status (live)",
      "id": 20,
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_in_status", "legendFormat": "{{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Streams by state",
      "id": 21,
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_streams_in_state", "legendFormat": "{{state}}", "refId": "A"}]
    },

    {
      "type": "timeseries",
      "title": "DLE source up (1=connected, 0=down)",
      "id": 30,
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_dle_source_up", "legendFormat": "{{source}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"max": 1, "min": 0}}
    },
    {
      "type": "timeseries",
      "title": "Stream uptime (minutes)",
      "id": 31,
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_stream_uptime_seconds / 60", "legendFormat": "{{stream}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "m"}}
    }
  ]
}
