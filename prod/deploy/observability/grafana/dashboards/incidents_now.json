{
  "uid": "cff-incidents",
  "title": "CFF — Incidents Now",
  "tags": ["cff", "alerts"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {"from": "now-24h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "type": "alertlist",
      "title": "Firing alerts",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "options": {
        "showOptions": "current",
        "stateFilter": {"firing": true, "pending": true},
        "maxItems": 50,
        "sortOrder": 1
      }
    },
    {
      "type": "logs",
      "title": "Last hour: ERROR + CRITICAL across CFF",
      "id": 2,
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{unit=~\"cff-.*\"} |~ \"ERROR|CRITICAL\" | json | line_format \"[{{.unit}}] {{.MESSAGE}}\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "sortOrder": "Descending"}
    },
    {
      "type": "stat",
      "title": "Tasks failed (1h)",
      "id": 5,
      "gridPos": {"x": 0, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_failed_recent{window=\"1h\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["last"]}}
    },
    {
      "type": "stat",
      "title": "Tasks failed (24h)",
      "id": 6,
      "gridPos": {"x": 6, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_failed_recent{window=\"24h\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["last"]}}
    },
    {
      "type": "stat",
      "title": "DLE sources up",
      "id": 7,
      "gridPos": {"x": 12, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(cff_dle_source_up)", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 5, "color": "yellow"}, {"value": 7, "color": "green"}]}}}
    },
    {
      "type": "stat",
      "title": "Streams running",
      "id": 8,
      "gridPos": {"x": 18, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(cff_stream_active)", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 5, "color": "yellow"}, {"value": 9, "color": "green"}]}}}
    }
  ]
}
