{
  "uid": "cff-pipeline",
  "title": "CFF — Task Pipeline",
  "tags": ["cff", "tasks"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "type": "stat",
      "title": "Created (1h)",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_created_recent{window=\"1h\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["last"]}}
    },
    {
      "type": "stat",
      "title": "Completed (1h)",
      "id": 2,
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_completed_recent{window=\"1h\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["last"]}}
    },
    {
      "type": "stat",
      "title": "Failed (1h)",
      "id": 3,
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_failed_recent{window=\"1h\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["last"]}},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 5, "color": "yellow"}, {"value": 20, "color": "red"}]}}}
    },
    {
      "type": "stat",
      "title": "Failure rate (1h)",
      "id": 4,
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 * cff_tasks_failed_recent{window=\"1h\"} / clamp_min(cff_tasks_created_recent{window=\"1h\"}, 1)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["last"]}},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 10, "color": "yellow"}, {"value": 30, "color": "red"}]}}}
    },

    {
      "type": "timeseries",
      "title": "Tasks by status (live from DB)",
      "id": 10,
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_tasks_in_status", "legendFormat": "{{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Worker job duration p95 by worker",
      "id": 11,
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (worker, le) (rate(cff_worker_job_duration_seconds_bucket[10m])))", "legendFormat": "{{worker}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },

    {
      "type": "timeseries",
      "title": "Worker outcomes (jobs/min)",
      "id": 20,
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (worker, outcome) (rate(cff_worker_jobs_total[5m])) * 60", "legendFormat": "{{worker}} • {{outcome}}", "refId": "A"}]
    },
    {
      "type": "table",
      "title": "YouTube tokens — hours to expiry",
      "id": 21,
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cff_youtube_token_expires_in_seconds / 3600", "refId": "A", "format": "table", "instant": true}],
      "fieldConfig": {"defaults": {"unit": "h", "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 24, "color": "yellow"}, {"value": 72, "color": "green"}]}}},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "instance": true, "job": true, "service": true, "host": true}}}
      ]
    },

    {
      "type": "logs",
      "title": "Recent ERRORS in pipeline",
      "id": 30,
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 10},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{unit=~\"cff-.*\"} |~ \"ERROR|CRITICAL\" | json | line_format \"{{.MESSAGE}}\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
