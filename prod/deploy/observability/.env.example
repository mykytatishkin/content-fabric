# Copy to .env and fill values:
# cp .env.example .env

# ── Grafana ─────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# ── GlitchTip ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
GLITCHTIP_SECRET_KEY=change-me-must-be-at-least-32-characters-long
GLITCHTIP_DB_PASSWORD=change-me

# ── Email (alerts) ──────────────────────────────────────────────────
# Stub for now — real SMTP credentials provided later.
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
