[Unit]
Description=Content Fabric API Gateway (FastAPI/uvicorn)
After=network.target mysql.service redis.service
Wants=redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/cff/prod
EnvironmentFile=/root/cff/.env
EnvironmentFile=/root/cff/prod/.env/.env.db
EnvironmentFile=/root/cff/prod/.env/.env.api
ExecStart=/root/cff/prod/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=append:/var/log/cff-api.log
StandardError=append:/var/log/cff-api.log

[Install]
WantedBy=multi-user.target
